+import json
+import os
+import re
+import urllib.error
+import urllib.request
+from abc import ABC
+from typing import Dict, Optional, cast
+
+import numpy as np
+from loguru import logger
+from pydantic import BaseModel, Field
+
+from chat_engine.common.handler_base import HandlerBase, HandlerBaseInfo, HandlerDataInfo, HandlerDetail
+from chat_engine.contexts.handler_context import HandlerContext
+from chat_engine.contexts.session_context import SessionContext
+from chat_engine.data_models.chat_data.chat_data_model import ChatData
+from chat_engine.data_models.chat_data_type import ChatDataType
+from chat_engine.data_models.chat_engine_config_data import ChatEngineConfigModel, HandlerBaseConfigModel
+from chat_engine.data_models.chat_signal import ChatSignal, SignalFilterRule
+from chat_engine.data_models.chat_signal_type import ChatSignalType
+from chat_engine.data_models.runtime_data.data_bundle import DataBundle, DataBundleDefinition, DataBundleEntry
+
+
+def pcm16le_to_float32(pcm: bytes) -> np.ndarray:
+    return (np.frombuffer(pcm, dtype=np.int16).astype(np.float32) / 32767)[np.newaxis, ...]
+
+
+def split_complete_sentences(text: str):
+    parts = re.split(r"(?<=[,.~!?，。！？])", text)
+    if len(parts) <= 1:
+        return [], text
+    return [part for part in parts[:-1] if part.strip()], parts[-1]
+
+
+class TTSConfig(HandlerBaseConfigModel, BaseModel):
+    api_key: str = Field(default_factory=lambda: os.getenv("BOSON_API_KEY", ""))
+    base_url: str = Field(default_factory=lambda: os.getenv("BOSON_BASE_URL", "https://api.boson.ai"))
+    model_name: str = Field(default_factory=lambda: os.getenv("BOSON_TTS_MODEL", "higgs-audio-v3-tts"))
+    voice: str = Field(default_factory=lambda: os.getenv("BOSON_TTS_VOICE", "default"))
+    sample_rate: int = Field(default=24000)
+    timeout_sec: float = Field(default=30)
+    chunk_bytes: int = Field(default=4800)
+
+
+class TTSContext(HandlerContext):
+    def __init__(self, session_id: str):
+        super().__init__(session_id)
+        self.input_text = ""
+        self.cancelled = False
+
+
+class HandlerTTS(HandlerBase, ABC):
+    def __init__(self):
+        super().__init__()
+        self.api_key = ""
+        self.speech_url = ""
+        self.model_name = ""
+        self.voice = ""
+        self.sample_rate = 24000
+        self.timeout_sec = 30
+        self.chunk_bytes = 4800
+
+    def get_handler_info(self) -> HandlerBaseInfo:
+        return HandlerBaseInfo(config_model=TTSConfig)
+
+    def load(self, engine_config: ChatEngineConfigModel, handler_config: Optional[BaseModel] = None):
+        config = cast(TTSConfig, handler_config)
+        self.api_key = config.api_key
+        self.speech_url = config.base_url.rstrip("/") + "/v1/audio/speech"
+        self.model_name = config.model_name
+        self.voice = config.voice
+        self.sample_rate = config.sample_rate
+        self.timeout_sec = config.timeout_sec
+        self.chunk_bytes = max(2, config.chunk_bytes - (config.chunk_bytes % 2))
+
+    def create_context(self, session_context: SessionContext, handler_config=None):
+        return TTSContext(session_context.session_info.session_id)
+
+    def start_context(self, session_context: SessionContext, handler_context: HandlerContext):
+        pass
+
+    def get_handler_detail(self, session_context: SessionContext, context: HandlerContext) -> HandlerDetail:
+        definition = DataBundleDefinition()
+        definition.add_entry(DataBundleEntry.create_audio_entry("avatar_audio", 1, self.sample_rate))
+        return HandlerDetail(
+            inputs=[HandlerDataInfo(type=ChatDataType.AVATAR_TEXT)],
+            outputs=[HandlerDataInfo(type=ChatDataType.AVATAR_AUDIO, definition=definition)],
+            signal_filters=[SignalFilterRule(ChatSignalType.STREAM_CANCEL, None, None)],
+        )
+
+    def filter_text(self, text: str) -> str:
+        return re.sub(r"[^a-zA-Z0-9\u4e00-\u9fff,.\~!?，。！？ ]", "", text)
+
+    def handle(self, context: HandlerContext, inputs: ChatData,
+               output_definitions: Dict[ChatDataType, HandlerDataInfo]):
+        if inputs.type != ChatDataType.AVATAR_TEXT:
+            return
+
+        context = cast(TTSContext, context)
+        output_definition = output_definitions.get(ChatDataType.AVATAR_AUDIO).definition
+        text = inputs.data.get_main_data()
+        if text:
+            context.input_text += self.filter_text(re.sub(r"<\|.*?\|>", "", text))
+
+        if not (inputs.is_last_data or inputs.data.get_meta("avatar_text_end", False)):
+            sentences, context.input_text = split_complete_sentences(context.input_text)
+            for sentence in sentences:
+                self._speak(context, output_definition, sentence)
+            return
+
+        if context.input_text.strip():
+            self._speak(context, output_definition, context.input_text)
+        context.input_text = ""
+        if not context.cancelled:
+            self._finish_stream(context, output_definition)
+        context.cancelled = False
+
+    def _speak(self, context: TTSContext, output_definition: DataBundleDefinition, text: str):
+        if context.cancelled or not text.strip():
+            return
+
+        # ponytail: blocking per sentence; move to a worker only if interruption during long TTS becomes painful.
+        payload = {
+            "model": self.model_name,
+            "input": text,
+            "voice": self.voice,
+            "response_format": "pcm",
+            "stream": True,
+        }
+        req = urllib.request.Request(
+            self.speech_url,
+            data=json.dumps(payload).encode("utf-8"),
+            headers={"Content-Type": "application/json"},
+            method="POST",
+        )
+        if self.api_key:
+            req.add_header("Authorization", "Bearer " + self.api_key)
+
+        pending = b""
+        try:
+            with urllib.request.urlopen(req, timeout=self.timeout_sec) as res:
+                while not context.cancelled:
+                    chunk = res.read(4096)
+                    if not chunk:
+                        break
+                    pending += chunk
+                    if len(pending) >= self.chunk_bytes:
+                        pending = self._submit_pcm(context, output_definition, pending)
+                if pending and not context.cancelled:
+                    self._submit_pcm(context, output_definition, pending)
+        except urllib.error.HTTPError as err:
+            logger.error(f"Higgs TTS HTTP {err.code}: {err.read(1024).decode('utf-8', 'ignore')}")
+        except Exception as err:
+            logger.error(f"Higgs TTS failed: {err}")
+
+    def _submit_pcm(self, context: TTSContext, output_definition: DataBundleDefinition, pcm: bytes) -> bytes:
+        usable = len(pcm) - (len(pcm) % 2)
+        if usable <= 0:
+            return pcm
+        output = DataBundle(output_definition)
+        output.set_main_data(pcm16le_to_float32(pcm[:usable]))
+        context.submit_data(output)
+        return pcm[usable:]
+
+    def _finish_stream(self, context: TTSContext, output_definition: DataBundleDefinition):
+        output = DataBundle(output_definition)
+        output.set_main_data(np.zeros(shape=(1, 240), dtype=np.float32))
+        context.submit_data(output, finish_stream=True)
+        logger.info("Higgs TTS: speech end")
+
+    def on_signal(self, context: HandlerContext, signal: ChatSignal):
+        if signal.type == ChatSignalType.STREAM_CANCEL:
+            cast(TTSContext, context).cancelled = True
+
+    def destroy_context(self, context: HandlerContext):
+        cast(TTSContext, context).cancelled = True
+
+
+def _demo():
+    audio = pcm16le_to_float32(np.array([-32768, 0, 32767], dtype=np.int16).tobytes())
+    assert audio.shape == (1, 3)
+    assert audio.dtype == np.float32
+    assert audio[0, 1] == 0
+    sentences, rest = split_complete_sentences("Hi. still going")
+    assert sentences == ["Hi."]
+    assert rest == " still going"
+
+
+if __name__ == "__main__":
+    _demo()
